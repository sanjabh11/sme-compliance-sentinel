{
  "name": "sme-workspace-sentinel",
  "version": "0.1.0",
  "private": true,
  "description": "AI DLP and SOC2 readiness evidence dashboard for seed-stage teams using Google Workspace.",
  "repository": {
    "type": "git",
    "url": "https://github.com/sanjabh11/sme-compliance-sentinel.git"
  },
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "build": "node scripts/run-next-build.mjs",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/run-vitest.mjs",
    "verify:source-release": "node scripts/verify-source-release.mjs",
    "verify:provenance": "node scripts/verify-project-provenance.mjs",
    "verify:cloudrun-deployment": "node scripts/verify-cloudrun-deployment.mjs",
    "write:cloudrun-values-template": "node scripts/render-cloudrun-manifest.mjs --write-values-template",
    "write:cloudrun-release-values": "node scripts/render-cloudrun-manifest.mjs --write-release-values",
    "audit:cloudrun-values": "node scripts/audit-cloudrun-render-values.mjs",
    "render:cloudrun-manifest": "node scripts/render-cloudrun-manifest.mjs",
    "prepare:cloudrun-dry-run": "node scripts/prepare-cloudrun-dry-run-packet.mjs",
    "verify:cloudrun-dry-run-packet": "node scripts/prepare-cloudrun-dry-run-packet.mjs --verify-packet",
    "collect:cloudrun-deployment": "node scripts/collect-cloudrun-deployment-transcript.mjs",
    "verify:production": "node scripts/verify-production-readiness.mjs",
    "collect:hosted-proof": "node scripts/collect-hosted-proof-bundle.mjs",
    "prepare:deployment-execution-checklist": "node scripts/prepare-deployment-execution-checklist.mjs",
    "import:hosted-proof": "node scripts/import-hosted-proof-bundle.mjs"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "lucide-react": "^0.468.0",
    "next": "16.2.6",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@next/eslint-plugin-next": "16.2.6",
    "@types/node": "^22.10.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint": "^9.16.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.17.0",
    "vitest": "^2.1.8"
  }
}
